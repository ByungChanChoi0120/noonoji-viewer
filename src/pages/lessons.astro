---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
const posts=(await getCollection('blog')).filter(p=>!p.data.draft && p.data.category==='lessons').sort((a,b)=>+new Date(b.data.date)-+new Date(a.data.date));
---
<BaseLayout title="수업 | 눈오지의 서재">
  <h2>🎓 수업</h2>
  {posts.map((post)=>(<article class="card"><h3><a href={`/posts/${post.id}/`}>{post.data.title}</a></h3><p class="muted">{post.data.date}</p><p>{post.data.summary}</p></article>))}
</BaseLayout>
