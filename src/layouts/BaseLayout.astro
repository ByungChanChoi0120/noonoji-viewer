---
const { title = '눈오지의 서재' } = Astro.props;
---
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <style>
      :root{
        --bg:#0b1220;
        --bg-soft:#111a2b;
        --card:#131f35;
        --card-2:#1b2a45;
        --fg:#e5edf9;
        --muted:#9fb1cc;
        --line:#294264;
        --brand:#7dd3fc;
        --accent:#60a5fa;
      }
      *{box-sizing:border-box}
      body{
        margin:0;
        color:var(--fg);
        background:
          radial-gradient(1000px 420px at 90% -10%, #1d4ed8 0%, transparent 60%),
          radial-gradient(900px 360px at -10% 0%, #0ea5e9 0%, transparent 58%),
          var(--bg);
        line-height:1.8;
        font-family:-apple-system,BlinkMacSystemFont,'Apple SD Gothic Neo','Noto Sans KR',sans-serif;
      }
      a{color:var(--brand);text-decoration:none}
      a:hover{text-decoration:underline}
      .muted{color:var(--muted);font-size:14px}
      .container{max-width:1140px;margin:22px auto;padding:0 16px 44px}

      .topbar{
        border:1px solid var(--line);
        border-radius:20px;
        background:linear-gradient(180deg,rgba(19,31,53,.94),rgba(17,26,43,.94));
        box-shadow:0 20px 44px rgba(2,6,23,.36);
        padding:16px;
        margin-bottom:18px;
      }
      .hero-strip{height:170px;border-radius:14px;background:url('/images/noonoji-hero.jpg') center/cover no-repeat;border:1px solid var(--line);margin-bottom:14px}
      .topbar-head{display:flex;justify-content:space-between;gap:14px;align-items:flex-start}
      .brand-wrap{display:flex;gap:12px;align-items:center}
      .avatar{width:62px;height:62px;border-radius:50%;object-fit:cover;border:2px solid #fff;box-shadow:0 8px 20px rgba(2,6,23,.45)}
      .brand{margin:0;font-size:34px;letter-spacing:-0.02em;color:#f8fbff}
      .brand-sub{margin:2px 0 0}
      .topnav{display:flex;gap:8px;flex-wrap:wrap}
      .pill{
        border:1px solid #2f4f75;
        border-radius:999px;
        padding:8px 12px;
        background:#162640;
        color:#dbeafe;
        font-size:13px;
        font-weight:700;
      }
      .pill:hover{background:#1f3356;text-decoration:none}

      .card{
        border:1px solid var(--line);
        border-radius:16px;
        padding:16px;
        background:linear-gradient(180deg,var(--card),var(--card-2));
        margin:12px 0;
        box-shadow:0 10px 26px rgba(2,6,23,.24);
      }
      .post-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:14px}
      h1,h2,h3{line-height:1.3;color:#f8fbff}
      h2{margin-top:20px}

      .prose{font-size:17px;color:#dbe7f6}
      .prose p{margin:0 0 14px}
      .prose h2{margin:26px 0 10px}
      .prose h3{margin:20px 0 8px}
      .prose ul,.prose ol{margin:8px 0 16px 22px}
      .prose img{width:100%;height:auto;border-radius:12px;border:1px solid var(--line)}

      @media (max-width: 760px){
        .topbar-head{flex-direction:column}
        .post-grid{grid-template-columns:1fr}
        .brand{font-size:28px}
      }
    </style>
  </head>
  <body>
    <div class="container">
      <header class="topbar">
        <div class="hero-strip"></div>
        <div class="topbar-head">
          <div class="brand-wrap">
            <img class="avatar" src="/images/noonoji-avatar.jpg" alt="눈오지 아바타" />
            <div>
              <a href="/"><h1 class="brand">눈오지의 서재</h1></a>
              <p class="muted brand-sub">운영 로그 · 수업 · 영상 아카이브</p>
            </div>
          </div>
          <nav class="topnav">
            <a class="pill" href="/all">전체</a>
            <a class="pill" href="/lessons">수업</a>
            <a class="pill" href="/worklog">업무일지</a>
            <a class="pill" href="/videos">영상</a>
            <a class="pill" href="/jeodanggeun">저당근</a>
          </nav>
        </div>
      </header>
      <main>
        <slot />
      </main>
    </div>
  </body>
</html>
