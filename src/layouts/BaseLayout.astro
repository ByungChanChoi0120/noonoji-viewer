---
const { title = '눈오지의 서재' } = Astro.props;
---
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <style>
      :root{
        --fg:#1a1a2e;
        --muted:#71717a;
        --border:#e4e4e7;
        --card:#ffffff;
        --brand:#3b82f6;
        --bg:#fafafa;
      }
      *{box-sizing:border-box;margin:0}
      body{
        color:var(--fg);
        background:var(--bg);
        line-height:1.8;
        font-family:'Apple SD Gothic Neo','Noto Sans KR',-apple-system,BlinkMacSystemFont,sans-serif;
      }
      a{color:var(--brand);text-decoration:none}
      a:hover{text-decoration:underline}
      .muted{color:var(--muted);font-size:14px}
      .wrap{max-width:720px;margin:0 auto;padding:24px 16px 48px}

      .header{
        padding:20px 0 16px;
        border-bottom:1px solid var(--border);
        margin-bottom:24px;
      }
      .header-top{display:flex;align-items:center;gap:12px;margin-bottom:8px}
      .avatar{width:48px;height:48px;border-radius:50%;object-fit:cover}
      .site-name{font-size:24px;font-weight:800;letter-spacing:-.02em}
      .site-desc{margin:0}
      .nav{display:flex;gap:6px;margin-top:10px;flex-wrap:wrap}
      .nav a{
        padding:6px 12px;
        border-radius:8px;
        font-size:14px;
        font-weight:600;
        color:var(--fg);
        background:#f4f4f5;
      }
      .nav a:hover{background:#e4e4e7;text-decoration:none}

      .card{
        border:1px solid var(--border);
        border-radius:12px;
        padding:14px;
        background:var(--card);
        margin:10px 0;
      }
      .post-grid{display:flex;flex-direction:column;gap:10px}
      h1{font-size:32px;font-weight:800;letter-spacing:-.02em;line-height:1.3;margin:8px 0 12px}
      h2{font-size:22px;font-weight:700;margin:20px 0 10px;line-height:1.3}
      h3{font-size:18px;font-weight:700;line-height:1.3}

      .prose{font-size:17px}
      .prose p{margin:0 0 14px}
      .prose h2{margin:28px 0 10px}
      .prose h3{margin:22px 0 8px}
      .prose ul,.prose ol{margin:8px 0 16px 20px}
      .prose img{width:100%;height:auto;border-radius:10px;border:1px solid var(--border);margin:8px 0}
      .prose blockquote{border-left:3px solid var(--brand);padding-left:14px;margin:12px 0;color:var(--muted)}

      @media (max-width:600px){
        .site-name{font-size:20px}
        h1{font-size:26px}
      }
    </style>
  </head>
  <body>
    <div class="wrap">
      <header class="header">
        <div class="header-top">
          <img class="avatar" src="/images/noonoji-avatar.jpg" alt="눈오지" />
          <div>
            <a href="/"><span class="site-name">눈오지의 서재</span></a>
            <p class="muted site-desc">운영 로그 · 수업 · 영상 아카이브</p>
          </div>
        </div>
        <nav class="nav">
          <a href="/all">전체</a>
          <a href="/lessons">수업</a>
          <a href="/worklog">업무일지</a>
          <a href="/videos">영상</a>
          <a href="/jeodanggeun">저당근</a>
        </nav>
      </header>
      <main>
        <slot />
      </main>
    </div>
  </body>
</html>
