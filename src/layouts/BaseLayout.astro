---
const { title = '눈오지의 서재' } = Astro.props;
---
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <style>
      :root{
        --fg:#0f172a;
        --muted:#64748b;
        --border:#dbe4f0;
        --card:#ffffff;
        --brand:#2563eb;
      }
      *{box-sizing:border-box}
      body{
        margin:0;
        color:var(--fg);
        line-height:1.8;
        font-family:-apple-system,BlinkMacSystemFont,'Apple SD Gothic Neo','Noto Sans KR',sans-serif;
        background:linear-gradient(180deg,#eef4ff 0%, #f8fbff 28%, #ffffff 100%);
      }
      a{color:var(--brand);text-decoration:none}
      a:hover{text-decoration:underline}
      .muted{color:var(--muted);font-size:14px}

      .shell{
        max-width:1180px;
        margin:0 auto;
        padding:20px 16px 40px;
        display:grid;
        grid-template-columns:260px 1fr;
        gap:18px;
      }
      .sidebar{
        position:sticky;
        top:16px;
        align-self:start;
        border:1px solid var(--border);
        border-radius:18px;
        background:#ffffffd9;
        backdrop-filter:blur(6px);
        box-shadow:0 12px 28px rgba(15,23,42,.08);
        padding:16px;
      }
      .brand{margin:0 0 2px;font-size:28px;letter-spacing:-.02em}
      .desc{margin-bottom:14px}
      .nav{display:flex;flex-direction:column;gap:8px}
      .nav a{
        border:1px solid #dbeafe;
        border-radius:12px;
        padding:9px 11px;
        background:#eff6ff;
        color:#1e3a8a;
        font-size:14px;
        font-weight:700;
      }
      .nav a:hover{text-decoration:none;background:#dbeafe}
      .content{min-width:0}
      .card{
        border:1px solid var(--border);
        border-radius:16px;
        padding:16px;
        background:var(--card);
        margin:12px 0;
        box-shadow:0 8px 20px rgba(15,23,42,.04);
      }
      .post-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:14px}
      h1,h2,h3{line-height:1.3}

      @media (max-width: 900px){
        .shell{grid-template-columns:1fr}
        .sidebar{position:static}
      }
      @media (max-width: 760px){
        .post-grid{grid-template-columns:1fr}
      }
    </style>
  </head>
  <body>
    <div class="shell">
      <aside class="sidebar">
        <a href="/"><h1 class="brand">눈오지의 서재</h1></a>
        <div class="muted desc">운영 로그 · 수업 · 영상 아카이브</div>
        <nav class="nav">
          <a href="/all">📚 전체</a>
          <a href="/lessons">🎓 수업</a>
          <a href="/worklog">📝 업무일지</a>
          <a href="/videos">📹 영상</a>
        </nav>
      </aside>
      <main class="content">
        <slot />
      </main>
    </div>
  </body>
</html>
